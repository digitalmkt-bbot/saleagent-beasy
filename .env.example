# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าตามต้องการ
DATABASE_URL=postgres://jubili:jubili@localhost:5432/jubili
JWT_SECRET=change-this-secret-in-production
PORT=4000
# DB ระบบ rate/master-setting (อ่านอย่างเดียว) — ใช้โดย /api/reports/b2b-dashboard และ import-agents
RATE_DATABASE_URL=postgresql://user:pass@host:port/railway
